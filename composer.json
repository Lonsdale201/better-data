{
  "name": "better-data/better-data",
  "description": "PHP 8.3+ DTO and Presenter library for WordPress — typed input hydration and contextual output shaping.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Soczó Kristóf",
      "email": "lonsdale201@hotmail.com"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5",
    "php-stubs/wordpress-stubs": "^6.9",
    "php-stubs/woocommerce-stubs": "^10.6"
  },
  "autoload": {
    "psr-4": {
      "BetterData\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BetterData\\Tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "analyse": "phpstan analyse",
    "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
    "cs-check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
